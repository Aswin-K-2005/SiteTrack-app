# Copy this to .env and fill in real values before deploying anywhere beyond your own laptop.

# Generate one with: python -c "import secrets; print(secrets.token_urlsafe(32))"
SECRET_KEY=change-this-to-a-long-random-string

ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=720

# For production, point this at Postgres instead, e.g.:
# DATABASE_URL=postgresql://user:password@localhost:5432/sitetrack
DATABASE_URL=sqlite:///./sitetrack.db

# Comma-separated list of frontend origins allowed to call this API
CORS_ORIGINS=http://localhost:5173,http://127.0.0.1:5173

# Seeded on first run only, if no admin exists yet. Change the password immediately after first login.
DEFAULT_ADMIN_USERNAME=admin
DEFAULT_ADMIN_PASSWORD=admin123
